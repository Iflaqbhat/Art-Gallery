# Maison Aman — frontend environment variables
#
# Copy this file to `.env` for local dev:
#   cp .env.example .env
#
# Then set the SAME variables on Netlify under:
#   Site settings → Environment variables
#
# Anything with the VITE_ prefix is bundled into the public production JS,
# so it's readable by anyone visiting the site. Every variable here is
# designed to be public — never put a "secret" key with a VITE_ prefix.

# ─── Supabase (REQUIRED) ─────────────────────────────────────────────────────
# Project URL — Supabase Dashboard → Settings → API → "Project URL"
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Anon (publishable) key — Supabase Dashboard → Settings → API → "anon" / "publishable".
# This is public on purpose. Row-Level Security on the database controls
# who can read/write what. NEVER put the "service_role" key here — that one
# bypasses RLS and must stay server-side (used only in scripts/.env locally).
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ─── Email forwarding for inquiries (OPTIONAL) ───────────────────────────────
# Without this key, every "Inquire" submission still saves to public.inquiries
# and shows up at /admin/inquiries. With it set, a copy is also forwarded to
# the curator's inbox via Web3Forms (free, https://web3forms.com).
#
# How to get one:
#   1. Visit https://web3forms.com → enter your email.
#   2. They email you an access key.
#   3. Paste it here and on Netlify.
VITE_WEB3FORMS_KEY=
