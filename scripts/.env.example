# Used by seed-data.js (and set-ceo-role.js, optionally).
# Copy this file to scripts/.env and fill in the value(s) you need.
#
# IMPORTANT: scripts/.env is git-ignored — never commit secrets.

# --- 1. Supabase URL (OPTIONAL) ---
# If you don't set this, the script falls back to VITE_SUPABASE_URL from
# frontend/.env, so you usually don't need to set it twice.
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# --- 2. Service-role key (REQUIRED) ---
# This is the *secret* server-side key that bypasses Row-Level Security.
# It is NOT the same as the anon/publishable key.
#
# Where to find it:
#   Supabase Dashboard → Project Settings → API → "service_role" (under
#   "Project API keys"). It starts with "ey" and is much longer than the
#   anon key.
SUPABASE_SERVICE_ROLE_KEY=ey...
